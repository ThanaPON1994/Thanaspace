-- SECTION 8: LOGGING & DIAGNOSTICS MODULE
--══════════════════════════════════════════════════════════════════════════════

local Logger = {}
Logger.Logs = {}
Logger.MaxLogs = 500

function Logger.Log(category, message, data)
    local entry = {
        Timestamp = tick(),
        Category = category,
        Message = message,
        Data = data
    }
    
    table.insert(Logger.Logs, entry)
    
    if #Logger.Logs > Logger.MaxLogs then
        table.remove(Logger.Logs, 1)
    end
    
    if ConfigManager.Settings.LOG_TO_CONSOLE then
        local prefix = string.format("[%-8s] %s", category, message)
        print(prefix)
        if data then
            print("  ->", ConfigManager.ToJSON(data, 0, 0):sub(1, 200))
        end
    end
end

function Logger.GetLogs(category, limit)
    limit = limit or 50
    local filtered = {}
    for i = #Logger.Logs, 1, -1 do
        if not category or Logger.Logs[i].Category == category then
            table.insert(filtered, Logger.Logs[i])
            if #filtered >= limit then break end
        end
    end
    return filtered
end

