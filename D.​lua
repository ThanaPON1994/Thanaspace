function RemoteInterceptor.HashArgs(args)
    local parts = {}
    for i, arg in ipairs(args) do
        table.insert(parts, tostring(typeof(arg)) .. ":" .. tostring(arg):sub(1, 50))
    end
    return table.concat(parts, "|")
end

function RemoteInterceptor.DeepInspect(value, depth, maxDepth)
    depth = depth or 0
    maxDepth = maxDepth or ConfigManager.Settings.MAX_ARGUMENT_DEPTH
    if depth > maxDepth then return {__type = typeof(value), __truncated = true} end
    
    local t = typeof(value)
    
    if t == "nil" or t == "boolean" or t == "number" or t == "string" then
        return value
    elseif t == "Vector2" then
        return {X = value.X, Y = value.Y, __type = "Vector2"}
    elseif t == "Vector3" then
        return {X = value.X, Y = value.Y, Z = value.Z, __type = "Vector3"}
    elseif t == "Color3" then
        return {
            R = value.R, G = value.G, B = value.B,
            Hex = string.format("#%02X%02X%02X", math.floor(value.R*255), math.floor(value.G*255), math.floor(value.B*255)),
            __type = "Color3"
        }
    elseif t == "CFrame" then
        local pos = value.Position
        return {Position = {X = pos.X, Y = pos.Y, Z = pos.Z}, __type = "CFrame"}
    elseif t == "EnumItem" then
        return {EnumType = tostring(value.EnumType), Name = value.Name, Value = value.Value, __type = "EnumItem"}
    elseif t == "Instance" then
        return {ClassName = value.ClassName, Name = value.Name, Path = value:GetFullName(), __type = "Instance"}
    elseif t == "table" then
        local result = {__type = "table", __len = #value}
        local count = 0
        for k, v in pairs(value) do
            count = count + 1
            if count > 50 then
                result.__truncated = true
                break
            end
            local key = typeof(k) == "string" and k or tostring(k)
            result[key] = RemoteInterceptor.DeepInspect(v, depth + 1, maxDepth)
        end
        return result
    elseif t == "buffer" then
        local len = buffer.len(value)
        local bytes = {}
        for i = 0, math.min(len - 1, 16) do
            table.insert(bytes, string.format("%02X", buffer.readu8(value, i)))
        end
        return {
            __type = "buffer",
            Length = len,
            Preview = table.concat(bytes, " ") .. (len > 16 and "..." or ""),
            __raw = "[buffer data]"
        }
    else
        return {__type = t, __value = tostring(value):sub(1, 100)}
    end
end

function RemoteInterceptor.ClassifyStroke(args)
    -- Analyze arguments to determine stroke type
    local analysis = {}
    for k, v in pairs(DataModels.StrokeAnalysis) do analysis[k] = v end
    
    -- Look for point data
    local points = {}
    local color = nil
    local thickness = nil
    local transparency = nil
    
    for _, arg in ipairs(args) do
        local t = typeof(arg)
        if t == "Vector2" or t == "Vector3" then
            table.insert(points, {X = arg.X, Y = arg.Y})
        elseif t == "Color3" then
            color = {R = arg.R, G = arg.G, B = arg.B, Hex = string.format("#%02X%02X%02X", math.floor(arg.R*255), math.floor(arg.G*255), math.floor(arg.B*255))}
        elseif t == "number" then
            if not thickness and arg > 0 and arg < 100 then
                thickness = arg
            elseif not transparency and arg >= 0 and arg <= 1 then
                transparency = arg
            end
        elseif t == "table" then
            -- Check if table contains points
            for k2, v2 in pairs(arg) do
                if typeof(v2) == "Vector2" then
                    table.insert(points, {X = v2.X, Y = v2.Y})
                elseif typeof(v2) == "Color3" then
                    color = {R = v2.R, G = v2.G, B = v2.B}
                end
            end
        elseif t == "buffer" then
            analysis.StrokeType = "buffer"
            analysis.PointCount = buffer.len(arg)
            return analysis
        end
    end
    
    analysis.Points = points
    analysis.PointCount = #points
    analysis.Color = color
    analysis.Thickness = thickness or 1
    analysis.Transparency = transparency or 0
    
    if #points == 0 then
        analysis.StrokeType = "unknown"
    elseif #points == 1 then
        analysis.StrokeType = "pixel"
        analysis.StartPoint = points[1]
        analysis.EndPoint = points[1]
    elseif #points == 2 then
        analysis.StrokeType = "straight_line"
        analysis.StartPoint = points[1]
        analysis.EndPoint = points[2]
    else
        analysis.StrokeType = "curve"
        analysis.StartPoint = points[1]
        analysis.EndPoint = points[#points]
    end
    
    return analysis
end

function RemoteInterceptor.HookRemote(remote)
    if not remote or not remote:IsA("RemoteEvent") then return end
    if RemoteInterceptor.HookedRemotes[remote] then return end
    
    local name = remote.Name
    local path = remote:GetFullName()
    local isDrawing, pattern = RemoteInterceptor.IsDrawingRelated(name)
    
    RemoteInterceptor.HookedRemotes[remote] = {
        Name = name,
        Path = path,
        IsDrawingRelated = isDrawing,
        Pattern = pattern,
        FireCount = 0,
        FirstFire = 0,
        LastFire = 0,
        Captures = {}
    }
    
    -- Hook FireServer
    local oldFireServer = remote.FireServer
    remote.FireServer = function(self, ...)
        local args = {...}
        local timestamp = tick()
        local capture = {}
        for k, v in pairs(DataModels.RemoteCapture) do capture[k] = v end
        
        capture.Timestamp = timestamp
        capture.RemotePath = path
        capture.RemoteName = name
        capture.EventType = "FireServer"
        capture.Arguments = RemoteInterceptor.DeepInspect(args)
        capture.ArgumentCount = #args
        capture.ArgumentTypes = {}
        for i, arg in ipairs(args) do
            capture.ArgumentTypes[i] = typeof(arg)
        end
        capture.IsDrawingRelated = isDrawing
        capture.FireCount = (RemoteInterceptor.HookedRemotes[remote].FireCount or 0) + 1
        
        if isDrawing then
            capture.DrawingClassification = RemoteInterceptor.ClassifyStroke(args).StrokeType
        end
        
        -- Rate tracking
        RemoteInterceptor.HookedRemotes[remote].FireCount = capture.FireCount
        if RemoteInterceptor.HookedRemotes[remote].FirstFire == 0 then
            RemoteInterceptor.HookedRemotes[remote].FirstFire = timestamp
        end
        RemoteInterceptor.HookedRemotes[remote].LastFire = timestamp
        
        table.insert(RemoteInterceptor.CaptureLog, capture)
        
        -- Limit log size
        if #RemoteInterceptor.CaptureLog > 1000 then
            table.remove(RemoteInterceptor.CaptureLog, 1)
        end
        
        -- Store in drawing remotes if relevant
        if isDrawing then
            if not RemoteInterceptor.DrawingRemotes[path] then
                RemoteInterceptor.DrawingRemotes[path] = {
                    Name = name,
                    Path = path,
                    Captures = {},
                    FireCount = 0
                }
            end
            table.insert(RemoteInterceptor.DrawingRemotes[path].Captures, capture)
            RemoteInterceptor.DrawingRemotes[path].FireCount = RemoteInterceptor.DrawingRemotes[path].FireCount + 1
        end
        
        -- Update rate tracker
        if not RemoteInterceptor.RateTracker[path] then
            RemoteInterceptor.RateTracker[path] = {
                Fires = {},
                Count = 0
            }
        end
        table.insert(RemoteInterceptor.RateTracker[path].Fires, timestamp)
        RemoteInterceptor.RateTracker[path].Count = RemoteInterceptor.RateTracker[path].Count + 1
        
        -- Trim old fires
        local cutoff = timestamp - 10
        while #RemoteInterceptor.RateTracker[path].Fires > 0 and 
              RemoteInterceptor.RateTracker[path].Fires[1] < cutoff do
            table.remove(RemoteInterceptor.RateTracker[path].Fires, 1)
        end
        
        return oldFireServer(self, ...)
    end
    
    -- Hook OnClientEvent if getconnections is available
    pcall(function()
        if getconnections then
            local conns = getconnections(remote.OnClientEvent)
            for _, conn in ipairs(conns) do
                local oldFunc = conn.Function
                if oldFunc and typeof(oldFunc) == "function" then
                    conn.Function = function(...)
                        local args = {...}
                        local timestamp = tick()
                        local capture = {}
                        for k, v in pairs(DataModels.RemoteCapture) do capture[k] = v end
                        
                        capture.Timestamp = timestamp
                        capture.RemotePath = path
                        capture.RemoteName = name
                        capture.EventType = "OnClientEvent"
                        capture.Arguments = RemoteInterceptor.DeepInspect(args)
                        capture.ArgumentCount = #args
                        capture.IsDrawingRelated = isDrawing
                        
                        table.insert(RemoteInterceptor.CaptureLog, capture)
                        
                        return oldFunc(...)
                    end
                end
            end
        end
    end)
end

function RemoteInterceptor.ScanAndHookRemotes()
    local rs = game:GetService("ReplicatedStorage")
    
    local function scanFolder(folder, depth)
        if depth > 5 then return end
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("UnreliableRemoteEvent") then
                RemoteInterceptor.HookRemote(child)
            elseif child:IsA("Folder") or child:IsA("Model") then
                scanFolder(child, depth + 1)
            end
        end
    end
    
    scanFolder(rs, 0)
    
    -- Also check RobloxReplicatedStorage
    pcall(function()
        local rrs = game:GetService("RobloxReplicatedStorage")
        scanFolder(rrs, 0)
    end)
end

function RemoteInterceptor.GetRateAnalysis(remotePath)
    local tracker = RemoteInterceptor.RateTracker[remotePath]
    if not tracker or #tracker.Fires < 2 then
        return {
            RemoteName = remotePath,
            FireCount = tracker and tracker.Count or 0,
            TimeSpan = 0,
            AverageRate = 0,
            PeakRate = 0,
            CooldownDetected = false,
            CooldownDuration = 0
        }
    end
    
    local fires = tracker.Fires
    local timeSpan = fires[#fires] - fires[1]
    local avgRate = timeSpan > 0 and (#fires / timeSpan) or 0
    
    -- Calculate peak rate using 1-second windows
    local peakRate = 0
    for i = 1, #fires do
        local windowStart = fires[i]
        local windowCount = 0
        for j = i, #fires do
            if fires[j] <= windowStart + 1 then
                windowCount = windowCount + 1
            else
                break
            end
        end
        peakRate = math.max(peakRate, windowCount)
    end
    
    -- Detect cooldown patterns
    local cooldownDetected = false
    local cooldownDuration = 0
    if #fires >= 3 then
        local gaps = {}
        for i = 2, #fires do
            table.insert(gaps, fires[i] - fires[i-1])
        end
        table.sort(gaps)
        local medianGap = gaps[math.floor(#gaps / 2)]
        if medianGap > 0.1 then
            cooldownDetected = true
            cooldownDuration = medianGap
        end
    end
    
    local analysis = {}
    for k, v in pairs(DataModels.RateAnalysis) do analysis[k] = v end
    analysis.RemoteName = remotePath
    analysis.FireCount = tracker.Count
    analysis.TimeSpan = timeSpan
    analysis.AverageRate = avgRate
    analysis.PeakRate = peakRate
    analysis.CooldownDetected = cooldownDetected
    analysis.CooldownDuration = cooldownDuration
    analysis.LastFireTime = fires[#fires]
    analysis.FireHistory = fires
    
    return analysis
end

