local CanvasDetector = {}
CanvasDetector.Results = {}
CanvasDetector.ScanHistory = {}
CanvasDetector.BestCandidate = nil

function CanvasDetector.IsBlacklisted(name)
    name = name:lower()
    for _, pattern in ipairs(ConfigManager.Settings.UI_BLACKLIST) do
        if name:find(pattern:lower()) then
            return true, pattern
        end
    end
    return false, nil
end

function CanvasDetector.IsPositiveIndicator(name)
    name = name:lower()
    local score = 0
    for _, pattern in ipairs(ConfigManager.Settings.CANVAS_POSITIVE) do
        if name:find(pattern:lower()) then
            score = score + 25
        end
    end
    return score
end

function CanvasDetector.GetInstancePath(instance)
    local path = instance.Name
    local parent = instance.Parent
    while parent do
        path = parent.Name .. "." .. path
        parent = parent.Parent
    end
    return path
end

function CanvasDetector.CountInputConnections(instance)
    local count = 0
    pcall(function()
        if getconnections then
            local conns = getconnections(instance.InputBegan)
            count = #conns
        end
    end)
    return count
end

function CanvasDetector.HasInputBeganConnection(instance)
    local count = CanvasDetector.CountInputConnections(instance)
    return count > 0, count
end

function CanvasDetector.AnalyzeGuiObject(obj, depth)
    local result = {}
    for k, v in pairs(DataModels.CanvasResult) do
        result[k] = v
    end
    
    local name = obj.Name
    local className = obj.ClassName
    local absSize = obj.AbsoluteSize
    local absPos = obj.AbsolutePosition
    
    -- Basic properties
    result.Instance = obj
    result.Path = CanvasDetector.GetInstancePath(obj)
    result.Name = name
    result.ClassName = className
    result.AbsoluteSize = absSize
    result.AbsolutePosition = absPos
    result.ZIndex = obj.ZIndex or 0
    result.Active = obj.Active or false
    result.Selectable = obj.Selectable or false
    result.ChildCount = #obj:GetChildren()
    result.IsVisible = obj.Visible ~= false
    
    -- Check blacklist
    local isBlacklisted, blacklistReason = CanvasDetector.IsBlacklisted(name)
    if isBlacklisted then
        result.Confidence = -100
        result.DetectionMethod = "blacklisted:" .. blacklistReason
        return result
    end
    
    -- Size-based detection
    local sizeScore = 0
    if absSize.X >= ConfigManager.Settings.MIN_CANVAS_SIZE.X and 
       absSize.Y >= ConfigManager.Settings.MIN_CANVAS_SIZE.Y then
        sizeScore = 30
        if absSize.X <= ConfigManager.Settings.MAX_CANVAS_SIZE.X and
           absSize.Y <= ConfigManager.Settings.MAX_CANVAS_SIZE.Y then
            sizeScore = sizeScore + 10
        end
    end
    
    -- Input detection
    local hasInput, inputCount = CanvasDetector.HasInputBeganConnection(obj)
    result.HasInputBegan = hasInput
    result.InputConnectionCount = inputCount
    local inputScore = hasInput and 25 or 0
    
    -- Name-based detection
    local nameScore = CanvasDetector.IsPositiveIndicator(name)
    
    -- Class-based detection
    local classScore = 0
    if className == "CanvasGroup" then classScore = 15
    elseif className == "Frame" then classScore = 10
    elseif className == "ImageLabel" then classScore = 10
    elseif className == "ImageButton" then classScore = 10
    elseif className == "TextButton" then classScore = 5
    elseif className == "ScrollingFrame" then classScore = 5
    end
    
    -- Child pattern detection
    local childScore = 0
    for _, child in ipairs(obj:GetChildren()) do
        local childName = child.Name:lower()
        if childName:find("stroke") or childName:find("line") or childName:find("draw") then
            childScore = childScore + 10
        end
        if childName:find("color") or childName:find("palette") or childName:find("picker") then
            childScore = childScore + 10
        end
        if child:IsA("UIStroke") or child:IsA("UIGradient") then
            childScore = childScore + 5
        end
    end
    
    -- Parent context
    local parentScore = 0
    local parent = obj.Parent
    if parent then
        local parentName = parent.Name:lower()
        if parentName:find("game") or parentName:find("match") or parentName:find("round") then
            parentScore = 10
        end
        if parentName:find("draw") or parentName:find("canvas") or parentName:find("art") then
            parentScore = parentScore + 15
        end
    end
    
    -- Visibility and interaction
    local interactionScore = 0
    if obj.Active then interactionScore = interactionScore + 5 end
    if obj.Selectable then interactionScore = interactionScore + 5 end
    if obj.Visible ~= false then interactionScore = interactionScore + 5 end
    
    -- Calculate total confidence
    result.Confidence = sizeScore + inputScore + nameScore + classScore + 
                       childScore + parentScore + interactionScore
    
    -- Determine detection method
    local methods = {}
    if sizeScore > 0 then table.insert(methods, "size") end
    if inputScore > 0 then table.insert(methods, "input") end
    if nameScore > 0 then table.insert(methods, "name") end
    if childScore > 0 then table.insert(methods, "child_pattern") end
    result.DetectionMethod = table.concat(methods, "+")
    
    -- Determine canvas type
    if result.Confidence >= 60 then
        result.CanvasType = "drawing"
        result.Found = true
    elseif result.Confidence >= 40 then
        result.CanvasType = "viewport"
    elseif result.Confidence >= 20 then
        result.CanvasType = "image"
    else
        result.CanvasType = "frame"
    end
    
    return result
end

function CanvasDetector.ScanPlayerGui(playerGui, depth)
    depth = depth or 0
    if depth > ConfigManager.Settings.MAX_SCAN_DEPTH then return end
    
    local candidates = {}
    
    local function scanRecursive(instance, currentDepth)
        if currentDepth > ConfigManager.Settings.MAX_SCAN_DEPTH then return end
        if not instance:IsA("GuiObject") then
            -- Still scan children of non-GuiObject containers
            for _, child in ipairs(instance:GetChildren()) do
                scanRecursive(child, currentDepth + 1)
            end
            return
        end
        
        local result = CanvasDetector.AnalyzeGuiObject(instance, currentDepth)
        table.insert(candidates, result)
        
        -- Scan children
        for _, child in ipairs(instance:GetChildren()) do
            scanRecursive(child, currentDepth + 1)
        end
    end
    
    -- Scan all ScreenGuis
    for _, screenGui in ipairs(playerGui:GetChildren()) do
        if screenGui:IsA("ScreenGui") then
            scanRecursive(screenGui, 0)
        end
    end
    
    -- Sort by confidence
    table.sort(candidates, function(a, b)
        return a.Confidence > b.Confidence
    end)
    
    return candidates
end

function CanvasDetector.ScanWorkspaceForCanvas()
    -- Some games use SurfaceGuis or BillboardGuis on parts
    local candidates = {}
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("SurfaceGui") or obj:IsA("BillboardGui") then
            local adornee = obj.Adornee or obj.Parent
            if adornee and adornee:IsA("BasePart") then
                local size = adornee.Size
                if size.X >= 5 and size.Y >= 5 then
                    local result = {}
                    for k, v in pairs(DataModels.CanvasResult) do result[k] = v end
                    result.Found = true
                    result.Instance = obj
                    result.Path = obj:GetFullName()
                    result.Name = obj.Name
                    result.AbsoluteSize = Vector2.new(size.X * 50, size.Y * 50) -- rough estimate
                    result.ClassName = obj.ClassName
                    result.Confidence = 50
                    result.CanvasType = "3d_surface"
                    result.DetectionMethod = "workspace_surface"
                    table.insert(candidates, result)
                end
            end
        end
    end
    
    return candidates
end

function CanvasDetector.GetBestCanvas()
    local allCandidates = {}
    
    -- Scan PlayerGui
    local player = game:GetService("Players").LocalPlayer
    if player and player:FindFirstChild("PlayerGui") then
        local guiCandidates = CanvasDetector.ScanPlayerGui(player.PlayerGui)
        for _, c in ipairs(guiCandidates) do
            table.insert(allCandidates, c)
        end
    end
    
    -- Scan Workspace
    local wsCandidates = CanvasDetector.ScanWorkspaceForCanvas()
    for _, c in ipairs(wsCandidates) do
        table.insert(allCandidates, c)
    end
    
    -- Sort by confidence
    table.sort(allCandidates, function(a, b)
        return a.Confidence > b.Confidence
    end)
    
    CanvasDetector.Results = allCandidates
    CanvasDetector.BestCandidate = allCandidates[1]
    
    return allCandidates
end

