local Main = {}
Main.IsRunning = false
Main.ScanCycle = 0
Main.LastExport = 0
Main.CompleteReport = {}

function Main.GenerateReport()
    local report = {}
    for k, v in pairs(DataModels.FullReport) do report[k] = v end
    
    report.ScanTimestamp = tick()
    report.PlaceId = game.PlaceId
    report.GameName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name or "Unknown"
    
    -- Canvas data
    report.Canvas = {
        BestCandidate = CanvasDetector.BestCandidate,
        AllCandidates = CanvasDetector.Results,
        CandidateCount = #CanvasDetector.Results
    }
    
    -- Remote data
    report.Remotes = {
        HookedCount = 0,
        DrawingRemotes = {},
        AllCaptures = RemoteInterceptor.CaptureLog
    }
    for _, data in pairs(RemoteInterceptor.HookedRemotes) do
        report.Remotes.HookedCount = report.Remotes.HookedCount + 1
    end
    for path, data in pairs(RemoteInterceptor.DrawingRemotes) do
        report.Remotes.DrawingRemotes[path] = data
    end
    
    -- Rate analysis
    report.Rates = {}
    for path, _ in pairs(RemoteInterceptor.RateTracker) do
        table.insert(report.Rates, RemoteInterceptor.GetRateAnalysis(path))
    end
    
    -- Colors
    report.Colors = ColorDetector.Palettes
    
    -- Anti-cheat
    report.AntiCheat = AntiCheatDetector.Findings
    
    -- Coordinate analysis (if we have canvas and strokes)
    report.Coordinates = {}
    if CanvasDetector.BestCandidate and CanvasDetector.BestCandidate.Found then
        for _, capture in ipairs(RemoteInterceptor.CaptureLog) do
            if capture.IsDrawingRelated and capture.DrawingClassification ~= "unknown" then
                local stroke = RemoteInterceptor.ClassifyStroke(capture.Arguments)
                local coordAnalysis = CoordinateAnalyzer.AnalyzeCoordinates(CanvasDetector.BestCandidate, stroke)
                table.insert(report.Coordinates, coordAnalysis)
                if #report.Coordinates >= 10 then break end
            end
        end
    end
    
    -- Metadata
    report.Metadata = {
        ScannerVersion = "7.0",
        ScanCycles = Main.ScanCycle,
        Runtime = tick() - (Main.StartTime or tick()),
        TotalCaptures = #RemoteInterceptor.CaptureLog,
        PlayerName = game:GetService("Players").LocalPlayer and game:GetService("Players").LocalPlayer.Name or "Unknown"
    }
    
    Main.CompleteReport = report
    return report
end

function Main.ExportReport()
    local report = Main.GenerateReport()
    local json = ConfigManager.SerializeReport(report)
    ConfigManager.CopyToClipboard(json)
    Logger.Log("EXPORT", "Report exported to clipboard", {Size = #json})
    return json
end

function Main.ScanCycle()
    Main.ScanCycle = Main.ScanCycle + 1
    
    -- Canvas detection
    ErrorHandler.SafeCall(function()
        CanvasDetector.GetBestCanvas()
    end, "CanvasScan")
    
    -- Remote hooking (continuous)
    ErrorHandler.SafeCall(function()
        RemoteInterceptor.ScanAndHookRemotes()
    end, "RemoteScan")
    
    -- Color palette detection
    ErrorHandler.SafeCall(function()
        ColorDetector.ScanForPalettes()
    end, "ColorScan")
    
    -- Anti-cheat scan (every 10 cycles)
    if Main.ScanCycle % 10 == 1 then
        ErrorHandler.SafeCall(function()
            AntiCheatDetector.ScanScripts()
        end, "ACScan")
    end
    
    -- Update UI
    if ConfigManager.Settings.UI_ENABLED then
        ErrorHandler.SafeCall(function()
            ScannerUI.UpdateCanvasSection(CanvasDetector.Results)
            ScannerUI.UpdateRemoteSection(RemoteInterceptor.DrawingRemotes)
            ScannerUI.UpdateColorSection(ColorDetector.Palettes)
        end, "UIUpdate")
    end
    
    -- Auto-export
    if ConfigManager.Settings.AUTO_EXPORT_CLIPBOARD then
        local now = tick()
        if now - Main.LastExport >= ConfigManager.Settings.EXPORT_INTERVAL then
            Main.LastExport = now
            Main.ExportReport()
        end
    end
    
    -- Log progress
    local canvasFound = CanvasDetector.BestCandidate and CanvasDetector.BestCandidate.Found
    local remoteCount = 0
    for _ in pairs(RemoteInterceptor.DrawingRemotes) do remoteCount = remoteCount + end
    local colorFound = #ColorDetector.Palettes > 0
    
    Logger.Log("SCAN", string.format("Cycle %d | Canvas: %s | DrawingRemotes: %d | Palettes: %d | AC: %d",
        Main.ScanCycle,
        canvasFound and "✓" or "✗",
        remoteCount,
        #ColorDetector.Palettes,
        #AntiCheatDetector.Findings
    ))
end

function Main.Start()
    if Main.IsRunning then return end
    Main.IsRunning = true
    Main.StartTime = tick()
    
    Logger.Log("SYSTEM", "KIRBY SCANNER v7.0 initializing...")
    
    -- Create UI
    if ConfigManager.Settings.UI_ENABLED then
        ErrorHandler.SafeCall(ScannerUI.Create, "CreateUI")
    end
    
    -- Initial scans
    Main.ScanCycle()
    
    -- Persistent scanning loop
    task.spawn(function()
        while Main.IsRunning do
            task.wait(ConfigManager.Settings.SCAN_INTERVAL)
            if not Main.IsRunning then break end
            Main.ScanCycle()
        end
    end)
    
    -- Watch for new remotes
    local rs = game:GetService("ReplicatedStorage")
    rs.DescendantAdded:Connect(function(descendant)
        if descendant:IsA("RemoteEvent") or descendant:IsA("UnreliableRemoteEvent") then
            ErrorHandler.SafeCall(function()
                RemoteInterceptor.HookRemote(descendant)
                Logger.Log("REMOTE", "New remote detected and hooked: " .. descendant.Name)
            end, "NewRemoteHook")
        end
    end)
    
    Logger.Log("SYSTEM", "Scanner active. Persistent monitoring enabled.")
