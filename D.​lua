local ColorDetector = {}
ColorDetector.Palettes = {}

function ColorDetector.ExtractColorFromInstance(instance)
    local colors = {}
    
    if instance:IsA("GuiObject") then
        if instance.BackgroundColor3 then
            table.insert(colors, instance.BackgroundColor3)
        end
        if instance:IsA("TextLabel") or instance:IsA("TextButton") or instance:IsA("TextBox") then
            if instance.TextColor3 then
                table.insert(colors, instance.TextColor3)
            end
        end
        if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
            if instance.ImageColor3 then
                table.insert(colors, instance.ImageColor3)
            end
        end
    end
    
    if instance:IsA("UIStroke") and instance.Color then
        table.insert(colors, instance.Color)
    end
    
    if instance:IsA("UIGradient") then
        for _, colorKeypoint in ipairs(instance.Color.Keypoints) do
            table.insert(colors, colorKeypoint.Value)
        end
    end
    
    return colors
end

function ColorDetector.ScanForPalettes()
    local palettes = {}
    local player = game:GetService("Players").LocalPlayer
    if not player or not player:FindFirstChild("PlayerGui") then return palettes end
    
    local function scanInstance(instance, depth)
        if depth > 8 then return end
        
        local name = instance.Name:lower()
        local isPalette = false
        
        -- Check name patterns
        if name:find("color") or name:find("palette") or name:find("picker") or
           name:find("swatch") or name:find("paint") or name:find("brush") then
            isPalette = true
        end
        
        -- Check if it's a container with many colored children
        local coloredChildren = 0
        local childColors = {}
        for _, child in ipairs(instance:GetChildren()) do
            local childColors2 = ColorDetector.ExtractColorFromInstance(child)
            for _, c in ipairs(childColors2) do
                coloredChildren = coloredChildren + 1
                table.insert(childColors, c)
            end
            -- Recurse for grandchildren
            if child:IsA("GuiObject") then
                for _, grandchild in ipairs(child:GetChildren()) do
                    if grandchild:IsA("GuiObject") then
                        local gcColors = ColorDetector.ExtractColorFromInstance(grandchild)
                        for _, c in ipairs(gcColors) do
                            coloredChildren = coloredChildren + 1
                            table.insert(childColors, c)
                        end
                    end
                end
            end
        end
        
        if coloredChildren >= 3 then
            isPalette = true
        end
        
        if isPalette and coloredChildren > 0 then
            -- Deduplicate colors
            local uniqueColors = {}
            local seen = {}
            for _, color in ipairs(childColors) do
                local key = string.format("%d,%d,%d", math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255))
                if not seen[key] then
                    seen[key] = true
                    table.insert(uniqueColors, color)
                end
            end
            
            if #uniqueColors >= 2 then
                local palette = {}
                for k, v in pairs(DataModels.ColorPalette) do palette[k] = v end
                palette.Found = true
                palette.Path = instance:GetFullName()
                palette.Name = instance.Name
                palette.ColorCount = #uniqueColors
                palette.Colors = uniqueColors
                palette.Format = "Color3"
                
                -- Determine selection method
                local hasClickable = false
                for _, child in ipairs(instance:GetChildren()) do
                    if child:IsA("TextButton") or child:IsA("ImageButton") then
                        hasClickable = true
                        break
                    end
                end
                palette.SelectionMethod = hasClickable and "click" or "property"
                
                -- Get samples
                for i = 1, math.min(10, #uniqueColors) do
                    local c = uniqueColors[i]
                    table.insert(palette.Samples, {
                        R = c.R, G = c.G, B = c.B,
                        Hex = string.format("#%02X%02X%02X", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
                    })
                end
                
                table.insert(palettes, palette)
            end
        end
        
        -- Continue scanning children
        for _, child in ipairs(instance:GetChildren()) do
            if child:IsA("GuiObject") or child:IsA("Folder") or child:IsA("Frame") then
                scanInstance(child, depth + 1)
            end
        end
    end
    
    for _, screenGui in ipairs(player.PlayerGui:GetChildren()) do
        if screenGui:IsA("ScreenGui") then
            scanInstance(screenGui, 0)
        end
    end
    
    ColorDetector.Palettes = palettes
    return palettes
end

