    label.TextSize = 11
    label.Font = Enum.Font.Code
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextWrapped = true
    label.AutomaticSize = Enum.AutomaticSize.Y
    label.Parent = parent
    
    return label
end

function ScannerUI.UpdateCanvasSection(canvasResults)
    if not ScannerUI.Content then return end
    
    -- Find or create section
    local section = ScannerUI.Content:FindFirstChild("Canvas")
    if not section then
        local s = ScannerUI.AddSection("📋 CANVAS", Color3.fromRGB(0, 200, 255))
        section = s.Section
        section.Name = "Canvas"
    end
    
    local body = section:FindFirstChild("Body")
    if not body then return end
    
    -- Clear old content
    for _, child in ipairs(body:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end
    
    if #canvasResults == 0 then
        ScannerUI.AddLine(body, "  Scanning for canvas...", Color3.fromRGB(255, 180, 0))
        return
    end
    
    local best = canvasResults[1]
    if best.Confidence <= 0 then
        ScannerUI.AddLine(body, "  No valid canvas found yet...", Color3.fromRGB(255, 100, 100))
        return
    end
    
    ScannerUI.AddLine(body, string.format("  ✓ BEST: %s", best.Name), Color3.fromRGB(0, 255, 136))
    ScannerUI.AddLine(body, string.format("    Path: %s", best.Path:sub(1, 50)), Color3.fromRGB(150, 150, 160))
    ScannerUI.AddLine(body, string.format("    Size: %.0f x %.0f", best.AbsoluteSize.X, best.AbsoluteSize.Y))
    ScannerUI.AddLine(body, string.format("    Confidence: %d%% | Type: %s", best.Confidence, best.CanvasType))
    ScannerUI.AddLine(body, string.format("    Input: %s (conns: %d)", tostring(best.HasInputBegan), best.InputConnectionCount))
    ScannerUI.AddLine(body, string.format("    Method: %s", best.DetectionMethod))
    
    if #canvasResults > 1 then
        ScannerUI.AddLine(body, string.format("  └─ %d other candidates", #canvasResults - 1), Color3.fromRGB(120, 120, 130))
    end
end

function ScannerUI.UpdateRemoteSection(drawingRemotes)
    if not ScannerUI.Content then return end
    
    local section = ScannerUI.Content:FindFirstChild("Remotes")
    if not section then
        local s = ScannerUI.AddSection("📡 REMOTES", Color3.fromRGB(255, 200, 0))
        section = s.Section
        section.Name = "Remotes"
    end
    
    local body = section:FindFirstChild("Body")
    if not body then return end
    
    for _, child in ipairs(body:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end
    
    local count = 0
    for path, data in pairs(drawingRemotes) do
        count = count + 1
        ScannerUI.AddLine(body, string.format("  ⚡ %s", data.Name), Color3.fromRGB(255, 220, 80))
        ScannerUI.AddLine(body, string.format("    Fires: %d | Captures: %d", data.FireCount, #data.Captures))
        if #data.Captures > 0 then
            local last = data.Captures[#data.Captures]
            ScannerUI.AddLine(body, string.format("    Last: %s", last.DrawingClassification or "unknown"), Color3.fromRGB(180, 180, 190))
        end
        if count >= 5 then
            ScannerUI.AddLine(body, "  ...", Color3.fromRGB(120, 120, 130))
            break
        end
    end
    
    if count == 0 then
        ScannerUI.AddLine(body, "  Waiting for drawing remotes...", Color3.fromRGB(255, 180, 0))
    end
end

function ScannerUI.UpdateColorSection(palettes)
    if not ScannerUI.Content then return end
    
    local section = ScannerUI.Content:FindFirstChild("Colors")
    if not section then
        local s = ScannerUI.AddSection("🎨 COLORS", Color3.fromRGB(255, 100, 200))
        section = s.Section
        section.Name = "Colors"
    end
    
    local body = section:FindFirstChild("Body")
    if not body then return end
    
    for _, child in ipairs(body:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end
    
    if #palettes == 0 then
        ScannerUI.AddLine(body, "  Scanning for palettes...", Color3.fromRGB(255, 180, 0))
        return
    end
    
    for i, palette in ipairs(palettes) do
        ScannerUI.AddLine(body, string.format("  ✓ %s (%d colors)", palette.Name, palette.ColorCount), Color3.fromRGB(255, 150, 220))
        local sampleStr = ""
        for j, sample in ipairs(palette.Samples) do
            sampleStr = sampleStr .. sample.Hex .. " "
            if j >= 5 then break end
        end
        ScannerUI.AddLine(body, string.format("    Samples: %s", sampleStr))
        if i >= 3 then break end
    end
end

function ScannerUI.UpdateStatus(status, color)
    if not ScannerUI.MainFrame then return end
    local title = ScannerUI.MainFrame:FindFirstChild("TitleBar")
    if not title then return end
    local titleText = title:FindFirstChild("Title")
    if titleText then
        titleText.Text = "🔍 KIRBY SCANNER v7.0 | " .. status
        if color then titleText.TextColor3 = color end
    end
end

