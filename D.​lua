-- SECTION 6: COORDINATE SYSTEM ANALYZER
--══════════════════════════════════════════════════════════════════════════════

local CoordinateAnalyzer = {}
CoordinateAnalyzer.Analysis = {}

function CoordinateAnalyzer.AnalyzeCoordinates(canvasResult, strokeData)
    local analysis = {
        CanvasSize = canvasResult and canvasResult.AbsoluteSize or Vector2.new(0, 0),
        CoordinateSystem = "unknown",
        CoordinateOrigin = "unknown",
        IsNormalized = false,
        IsPixel = false,
        IsWorld = false,
        BoundsCheck = {},
        ScaleFactor = 1,
        Offset = Vector2.new(0, 0)
    }
    
    if not strokeData or not strokeData.Points or #strokeData.Points == 0 then
        return analysis
    end
    
    local points = strokeData.Points
    local canvasSize = analysis.CanvasSize
    
    -- Check if coordinates are normalized (0-1 range)
    local allNormalized = true
    local allPixel = true
    local allWorld = true
    
    for _, point in ipairs(points) do
        local x, y = point.X, point.Y
        
        -- Normalized check
        if x < 0 or x > 1 or y < 0 or y > 1 then
            allNormalized = false
        end
        
        -- Pixel check (relative to canvas)
        if canvasSize.X > 0 and canvasSize.Y > 0 then
            if x > canvasSize.X * 1.5 or y > canvasSize.Y * 1.5 then
                allPixel = false
            end
        end
        
        -- World check (large values)
        if math.abs(x) < 100 and math.abs(y) < 100 then
            allWorld = false
        end
    end
    
    if allNormalized then
        analysis.CoordinateSystem = "normalized"
        analysis.IsNormalized = true
        analysis.CoordinateOrigin = "top_left"
        analysis.ScaleFactor = canvasSize.X > 0 and canvasSize.X or 1
    elseif allPixel then
        analysis.CoordinateSystem = "pixel"
        analysis.IsPixel = true
        analysis.CoordinateOrigin = "top_left"
        analysis.ScaleFactor = 1
    elseif allWorld then
        analysis.CoordinateSystem = "world"
        analysis.IsWorld = true
        analysis.CoordinateOrigin = "world"
    else
        analysis.CoordinateSystem = "mixed"
    end
    
    -- Bounds check
    if canvasSize.X > 0 and canvasSize.Y > 0 then
        for i, point in ipairs(points) do
            local inBounds = false
            if analysis.IsNormalized then
                inBounds = point.X >= 0 and point.X <= 1 and point.Y >= 0 and point.Y <= 1
            elseif analysis.IsPixel then
                inBounds = point.X >= 0 and point.X <= canvasSize.X and point.Y >= 0 and point.Y <= canvasSize.Y
            end
            analysis.BoundsCheck[i] = {
                Point = point,
                InBounds = inBounds,
                DistanceFromEdge = 0
            }
        end
    end
    
    return analysis
end

