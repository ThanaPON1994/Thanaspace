local ErrorHandler = {}

function ErrorHandler.SafeCall(func, context)
    local success, result = pcall(func)
    if not success then
        Logger.Log("ERROR", "Failed in " .. (context or "unknown"), {Error = tostring(result)})
        return nil, result
    end
    return result, nil
end

function ErrorHandler.SafeHook(remote, hookFunc)
    return ErrorHandler.SafeCall(function()
        return hookFunc(remote)
    end, "HookRemote:" .. remote.Name)
end

function ErrorHandler.ValidateCanvasResult(result)
    if not result then return false end
    if not result.Instance then return false end
    if result.Confidence < 0 then return false end
    if result.Instance.Parent == nil then return false end -- Destroyed
    return true
end

function ErrorHandler.SanitizeString(str)
    if not str then return "" end
    return str:gsub("[\n\r\t]", " "):sub(1, 500)
end

