-- JSON serialization implementation (no external dependencies)
function ConfigManager.ToJSON(value, indent, depth)
    indent = indent or 0
    depth = depth or 0
    
    if depth > 10 then return "\"[MAX_DEPTH]\"" end
    
    local t = typeof(value)
    
    if t == "nil" then
        return "null"
    elseif t == "boolean" then
        return tostring(value)
    elseif t == "number" then
        if value ~= value then return "\"NaN\""
        elseif value == math.huge then return "\"Infinity\""
        elseif value == -math.huge then return "\"-Infinity\""
        else return tostring(value) end
    elseif t == "string" then
        local escaped = value:gsub("\\", "\\\\"):gsub("\"", "\\\""):gsub("\n", "\\n"):gsub("\r", "\\r"):gsub("\t", "\\t")
        return "\"" .. escaped .. "\""
    elseif t == "Vector2" then
        return string.format("{\"X\":%s,\"Y\":%s,\"__type\":\"Vector2\"}", 
            ConfigManager.ToJSON(value.X, 0, depth+1),
            ConfigManager.ToJSON(value.Y, 0, depth+1))
    elseif t == "Vector3" then
        return string.format("{\"X\":%s,\"Y\":%s,\"Z\":%s,\"__type\":\"Vector3\"}",
            ConfigManager.ToJSON(value.X, 0, depth+1),
            ConfigManager.ToJSON(value.Y, 0, depth+1),
            ConfigManager.ToJSON(value.Z, 0, depth+1))
    elseif t == "Color3" then
        return string.format("{\"R\":%s,\"G\":%s,\"B\":%s,\"Hex\":\"%s\",\"__type\":\"Color3\"}",
            ConfigManager.ToJSON(value.R, 0, depth+1),
            ConfigManager.ToJSON(value.G, 0, depth+1),
            ConfigManager.ToJSON(value.B, 0, depth+1),
            string.format("#%02X%02X%02X", math.floor(value.R*255), math.floor(value.G*255), math.floor(value.B*255)))
    elseif t == "CFrame" then
        local pos = value.Position
        return string.format("{\"P\":{\"X\":%s,\"Y\":%s,\"Z\":%s},\"__type\":\"CFrame\"}",
            ConfigManager.ToJSON(pos.X, 0, depth+1),
            ConfigManager.ToJSON(pos.Y, 0, depth+1),
            ConfigManager.ToJSON(pos.Z, 0, depth+1))
    elseif t == "EnumItem" then
        return string.format("{\"EnumType\":\"%s\",\"Name\":\"%s\",\"Value\":%d}",
            tostring(value.EnumType), value.Name, value.Value)
    elseif t == "Instance" then
        return string.format("{\"__type\":\"Instance\",\"ClassName\":\"%s\",\"Name\":\"%s\",\"Path\":\"%s\"}",
            value.ClassName, value.Name, value:GetFullName())
    elseif t == "table" then
        -- Check if array-like
        local isArray = true
        local maxIndex = 0
        for k, _ in pairs(value) do
            if typeof(k) ~= "number" or k < 1 or k % 1 ~= 0 then
                isArray = false
                break
            end
            maxIndex = math.max(maxIndex, k)
        end
        if isArray and maxIndex ~= #value then isArray = false end
        
        local parts = {}
        local spacing = string.rep("  ", indent + 1)
        local endSpacing = string.rep("  ", indent)
        
        if isArray then
            for i, v in ipairs(value) do
                table.insert(parts, spacing .. ConfigManager.ToJSON(v, indent + 1, depth + 1))
            end
            if #parts == 0 then return "[]" end
            return "[\n" .. table.concat(parts, ",\n") .. "\n" .. endSpacing .. "]"
        else
            for k, v in pairs(value) do
                local key = typeof(k) == "string" and k or "[" .. ConfigManager.ToJSON(k, 0, depth+1) .. "]"
                table.insert(parts, spacing .. "\"" .. key .. "\":" .. ConfigManager.ToJSON(v, indent + 1, depth + 1))
            end
            if #parts == 0 then return "{}" end
            return "{\n" .. table.concat(parts, ",\n") .. "\n" .. endSpacing .. "}"
        end
    elseif t == "buffer" then
        local len = buffer.len(value)
        local bytes = {}
        for i = 0, math.min(len - 1, 32) do
            table.insert(bytes, string.format("%02X", buffer.readu8(value, i)))
        end
        local preview = table.concat(bytes, " ")
        if len > 32 then preview = preview .. " ... (" .. len .. " bytes)" end
        return string.format("{\"__type\":\"buffer\",\"len\":%d,\"preview\":\"%s\"}", len, preview)
    else
        return "\"" .. tostring(value):gsub("\"", "\\\"") .. "\""
    end
end

function ConfigManager.SerializeReport(report)
