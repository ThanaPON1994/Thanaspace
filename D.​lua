-- SECTION 7: ANTI-CHEAT DETECTOR
--══════════════════════════════════════════════════════════════════════════════

local AntiCheatDetector = {}
AntiCheatDetector.Findings = {}

function AntiCheatDetector.ScanScripts()
    local findings = {}
    
    local function scanScript(script)
        if not script:IsA("LocalScript") and not script:IsA("ModuleScript") then return end
        
        local name = script.Name:lower()
        local source = ""
        pcall(function()
            source = decompile and decompile(script) or ""
        end)
        
        for _, pattern in ipairs(ConfigManager.Settings.ANTICHEAT_PATTERNS) do
            if name:find(pattern:lower()) then
                local finding = {}
                for k, v in pairs(DataModels.AntiCheatEntry) do finding[k] = v end
                finding.ScriptPath = script:GetFullName()
                finding.ScriptName = script.Name
                finding.DetectionType = pattern
                finding.Severity = "high"
                finding.Details = {NameMatch = pattern}
                finding.CodeSnippet = source:sub(1, 500)
                table.insert(findings, finding)
            end
        end
        
        -- Check source code if available
        if source and source ~= "" then
            local suspiciousPatterns = {
                "mouse", "position", "validate", "check", "rate", "limit",
                "heartbeat", "renderstepped", "stepped", "tick", "os.clock"
            }
            for _, sp in ipairs(suspiciousPatterns) do
                if source:lower():find(sp) then
                    local alreadyFound = false
                    for _, f in ipairs(findings) do
                        if f.ScriptPath == script:GetFullName() then
                            alreadyFound = true
                            break
                        end
                    end
                    if not alreadyFound then
                        local finding = {}
                        for k, v in pairs(DataModels.AntiCheatEntry) do finding[k] = v end
                        finding.ScriptPath = script:GetFullName()
                        finding.ScriptName = script.Name
                        finding.DetectionType = "source_pattern:" .. sp
                        finding.Severity = "medium"
                        finding.Details = {Pattern = sp}
                        finding.CodeSnippet = source:sub(1, 500)
                        table.insert(findings, finding)
                    end
                end
            end
        end
    end
    
    -- Scan PlayerScripts
    local player = game:GetService("Players").LocalPlayer
    if player and player:FindFirstChild("PlayerScripts") then
        for _, script in ipairs(player.PlayerScripts:GetDescendants()) do
            if script:IsA("LocalScript") or script:IsA("ModuleScript") then
                scanScript(script)
            end
        end
    end
    
    -- Scan ReplicatedStorage modules
    local rs = game:GetService("ReplicatedStorage")
    for _, script in ipairs(rs:GetDescendants()) do
        if script:IsA("ModuleScript") then
            scanScript(script)
        end
    end
    
    AntiCheatDetector.Findings = findings
    return findings
end

