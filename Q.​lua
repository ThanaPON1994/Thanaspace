        drums = {0.4, 0.3, 0.3},
        elephant = {0.3, 0.3, 0.4},
        flamingo = {0.4, 0.2, 0.4},
        piano = {0.3, 0.4, 0.3},
    }
    local weights = themeWeights[theme] or {0.4, 0.3, 0.3}
    local score = smoothness * weights[1] + density * weights[2] + aspect * weights[3]
    return math.max(0, math.min(100, score)), smoothness, density, aspect
end

-- ========== NEW V15.0 METRICS ==========

function calculatePointConsistency(strokes)
    local counts = {}
    local total = 0
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            table.insert(counts, #s[1])
            total = total + #s[1]
        end
    end
    if #counts == 0 then return 0 end
    local mean = total / #counts
    local variance = 0
    for _, c in ipairs(counts) do
        variance = variance + (c - mean)^2
    end
    variance = variance / #counts
    local stdDev = math.sqrt(variance)
    local cv = (mean > 0) and (stdDev / mean) or 0
    return math.max(0, 100 - cv * 150)
end

function calculateSpatialDistribution(strokes)
    local minX, maxX, minY, maxY = math.huge, -math.huge, math.huge, -math.huge
    local hasPoints = false
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            for i = 1, #s[1] do
                minX = math.min(minX, s[1][i])
                maxX = math.max(maxX, s[1][i])
                minY = math.min(minY, s[2][i])
                maxY = math.max(maxY, s[2][i])
                hasPoints = true
            end
        end
    end
    if not hasPoints then return 0 end
    local w = maxX - minX
    local h = maxY - minY
    if w == 0 or h == 0 then return 0 end
    local grid = 3
    local occupied = {}
    for i = 1, grid do for j = 1, grid do occupied[(i-1)*grid+j] = false end end
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            for i = 1, #s[1] do
                local gx = math.min(grid, math.max(1, math.floor((s[1][i] - minX) / w * grid) + 1))
                local gy = math.min(grid, math.max(1, math.floor((s[2][i] - minY) / h * grid) + 1))
                occupied[(gy-1)*grid + gx] = true
            end
        end
    end
    local count = 0
    for _, v in pairs(occupied) do if v then count = count + 1 end end
    return (count / (grid * grid)) * 100
end

function calculateCurvatureQuality(strokes)
    local totalCurvature = 0
    local totalLength = 0
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] >= 3 then
            local strokeLen = 0
            local curv = 0
            for i = 2, #s[1] do
                local dx = s[1][i] - s[1][i-1]
                local dy = s[2][i] - s[2][i-1]
                strokeLen = strokeLen + math.sqrt(dx*dx + dy*dy)
            end
            for i = 2, #s[1]-1 do
                local vx1 = s[1][i] - s[1][i-1]
                local vy1 = s[2][i] - s[2][i-1]
                local vx2 = s[1][i+1] - s[1][i]
                local vy2 = s[2][i+1] - s[2][i]
                local cross = vx1*vy2 - vy1*vx2
                curv = curv + math.abs(cross)
            end
            totalCurvature = totalCurvature + curv
            totalLength = totalLength + strokeLen
        end
    end
    if totalLength == 0 then return 0 end
    local curvaturePerUnit = totalCurvature / totalLength
    return math.max(0, math.min(100, 100 - curvaturePerUnit * 0.02))
end

function calculateIntersectionScore(strokes)
    local segments = {}
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] >= 2 then
            for i = 2, #s[1] do
                table.insert(segments, {
                    x1 = s[1][i-1], y1 = s[2][i-1],
                    x2 = s[1][i],   y2 = s[2][i]
                })
            end
        end
    end
    local intersectCount = 0
    for i = 1, #segments do
        for j = i+1, #segments do
            local a1 = segments[i]
            local a2 = segments[j]
            local d = (a2.y2 - a2.y1)*(a1.x2 - a1.x1) - (a2.x2 - a2.x1)*(a1.y2 - a1.y1)
            if d ~= 0 then
                local u = ((a2.x2 - a2.x1)*(a1.y1 - a2.y1) - (a2.y2 - a2.y1)*(a1.x1 - a2.x1)) / d
                local v = ((a1.x2 - a1.x1)*(a1.y1 - a2.y1) - (a1.y2 - a1.y1)*(a1.x1 - a2.x1)) / d
                if u > 0 and u < 1 and v > 0 and v < 1 then
                    intersectCount = intersectCount + 1
                end
            end
        end
    end
    local n = #segments
    if n == 0 then return 0 end
    local ratio = intersectCount / n
    return math.min(100, ratio * 200)
end

function calculateComplexityScore(strokes)
    local totalPoints = 0
    local totalReversals = 0
    local totalSegments = 0
    local strokeCount = 0
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            strokeCount = strokeCount + 1
            totalPoints = totalPoints + #s[1]
            if #s[1] >= 3 then
                for i = 2, #s[1] - 1 do
                    local vx1 = s[1][i] - s[1][i-1]
                    local vy1 = s[2][i] - s[2][i-1]
                    local vx2 = s[1][i+1] - s[1][i]
                    local vy2 = s[2][i+1] - s[2][i]
                    local dot = vx1 * vx2 + vy1 * vy2
                    local mag1 = math.sqrt(vx1^2 + vy1^2)
                    local mag2 = math.sqrt(vx2^2 + vy2^2)
                    if mag1 > 0 and mag2 > 0 then
                        if dot < -0.3 then
                            totalReversals = totalReversals + 1
                        end
                        totalSegments = totalSegments + 1
                    end
                end
            end
        end
    end
    if strokeCount == 0 then return 0 end
    local complexity = (totalPoints / strokeCount) * 0.5 + (totalReversals / math.max(1,totalSegments)) * 50
    return math.min(100, complexity)
end

function calculateSymmetryScore(strokes)
    local minX, maxX, minY, maxY = math.huge, -math.huge, math.huge, -math.huge
    local hasPoints = false
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            for i = 1, #s[1] do
                minX = math.min(minX, s[1][i])
                maxX = math.max(maxX, s[1][i])
                minY = math.min(minY, s[2][i])
                maxY = math.max(maxY, s[2][i])
                hasPoints = true
            end
        end
    end
    if not hasPoints then return 0 end
    local cx = (minX + maxX) / 2
    local totalDist = 0
    local pointCount = 0
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            for i = 1, #s[1] do
                local mx = 2*cx - s[1][i]
                local nearestDist = math.huge
                for _, s2 in ipairs(strokes) do
                    if #s2 >= 2 and #s2[1] > 0 then
                        for j = 1, #s2[1] do
                            local dx = mx - s2[1][j]
                            local dy = s[2][i] - s2[2][j]
                            local d = math.sqrt(dx*dx + dy*dy)
                            if d < nearestDist then nearestDist = d end
                        end
                    end
                end
                totalDist = totalDist + nearestDist
                pointCount = pointCount + 1
            end
        end
    end
    if pointCount == 0 then return 0 end
    local avgDist = totalDist / pointCount
    local maxDim = math.max(maxX - minX, maxY - minY)
    if maxDim == 0 then return 0 end
    local sym = math.max(0, 100 - (avgDist / maxDim) * 200)
    return math.min(100, sym)
end

function calculateMultiScaleScore(strokes)
    local function getBoundingBox(strks)
        local mnx, mxx, mny, mxy = math.huge, -math.huge, math.huge, -math.huge
        local any = false
        for _, s in ipairs(strks) do
            if #s >= 2 and #s[1] > 0 then
                for i = 1, #s[1] do
                    mnx = math.min(mnx, s[1][i])
                    mxx = math.max(mxx, s[1][i])
                    mny = math.min(mny, s[2][i])
                    mxy = math.max(mxy, s[2][i])
                    any = true
                end
            end
        end
        if not any then return 0,0,0,0, false end
        return mnx, mxx, mny, mxy, true
    end
    local ox1, ox2, oy1, oy2, ok = getBoundingBox(strokes)
    if not ok then return 0 end
    local ow = ox2 - ox1
    local oh = oy2 - oy1
    if ow == 0 and oh == 0 then return 0 end
    local downStrokes = {}
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] >= 2 then
            local newS = { {}, {} }
            for i = 1, #s[1], 3 do
                table.insert(newS[1], s[1][i])
                table.insert(newS[2], s[2][i])
            end
            if #s[1] % 3 ~= 1 then
                table.insert(newS[1], s[1][#s[1]])
                table.insert(newS[2], s[2][#s[2]])
            end
            table.insert(downStrokes, newS)
        end
    end
    local dx1, dx2, dy1, dy2, dok = getBoundingBox(downStrokes)
    if not dok then return 0 end
    local dw = dx2 - dx1
    local dh = dy2 - dy1
    local areaRatio = (dw * dh) / math.max(1, ow * oh)
    local areaScore = 100 * (1 - math.abs(areaRatio - 1))
    return math.max(0, math.min(100, areaScore))
end

function calculateNeuralConfidence(strokes, theme)
    local smooth = calculateStrokeSmoothness(strokes)
    local density = calculateStrokeDensity(strokes)
    local aspect = calculateAspectBalance(strokes)
    local consistency = calculatePointConsistency(strokes)
    local distribution = calculateSpatialDistribution(strokes)
    local curvature = calculateCurvatureQuality(strokes)
    local intersection = calculateIntersectionScore(strokes)
    local complexity = calculateComplexityScore(strokes)
    local symmetry = calculateSymmetryScore(strokes)
    local multiScale = calculateMultiScaleScore(strokes)
    local confidence = (
        smooth * 0.15 + density * 0.10 + aspect * 0.08 +
        consistency * 0.05 + distribution * 0.05 + curvature * 0.12 +
        intersection * 0.05 + complexity * 0.10 + symmetry * 0.10 +
        multiScale * 0.20
    )
    local metrics = {
        smoothness = smooth, density = density, aspect = aspect,
        pointConsistency = consistency, spatialDistribution = distribution,
        curvatureQuality = curvature, intersectionScore = intersection,
        complexityScore = complexity, symmetryScore = symmetry,
        multiScaleScore = multiScale
    }
    return math.min(100, confidence), metrics
end

function calculateCrossValidationScore(strokes, theme)
    local expected = {
        strokes = {min=4, max=15, ideal=8},
        points = {min=50, max=300, ideal=120},
        aspectRatio = {min=0.5, max=2.0, ideal=1.0},
    }
    local strokeCount = 0
    local totalPoints = 0
    local minX, maxX, minY, maxY = math.huge, -math.huge, math.huge, -math.huge
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            strokeCount = strokeCount + 1
            totalPoints = totalPoints + #s[1]
            for i = 1, #s[1] do
                minX = math.min(minX, s[1][i])
                maxX = math.max(maxX, s[1][i])
                minY = math.min(minY, s[2][i])
                maxY = math.max(maxY, s[2][i])
            end
        end
    end
    local w = maxX - minX
    local h = maxY - minY
    local aspect = (h > 0 and w/h) or 0
    local function scoreStat(value, ex)
        local range = ex.max - ex.min
        if range == 0 then return 100 end
        local distFromIdeal = math.abs(value - ex.ideal)
        local scaled = 100 * (1 - distFromIdeal / (range/2))
        return math.max(0, math.min(100, scaled))
    end
    local s1 = scoreStat(strokeCount, expected.strokes)
    local s2 = scoreStat(totalPoints, expected.points)
    local s3 = scoreStat(aspect, expected.aspectRatio)
    return (s1 * 0.3 + s2 * 0.3 + s3 * 0.4)
end

function calculateTotalScore(strokes, theme)
    local confidence, _ = calculateNeuralConfidence(strokes, theme)
    local cvScore = calculateCrossValidationScore(strokes, theme)
    local multiScale = calculateMultiScaleScore(strokes)
    return confidence * 0.5 + cvScore * 0.3 + multiScale * 0.2
end

-- ========== V14.7 LEGACY FILTER (FROM V14.7) ==========
function isGoodDrawingLegacy(theme, strokes)
    if not strokes or #strokes == 0 then return false end
    local totalPoints = 0
    local strokesCount = 0
    local minX, maxX, minY, maxY = 9e9, -9e9, 9e9, -9e9
    for _, s in ipairs(strokes) do
        if #s >= 2 and #s[1] > 0 then
            strokesCount = strokesCount + 1
            for i = 1, #s[1] do
                totalPoints = totalPoints + 1
                minX = math.min(minX, s[1][i])
                maxX = math.max(maxX, s[1][i])
                minY = math.min(minY, s[2][i])
                maxY = math.max(maxY, s[2][i])
            end
        end
    end
    if strokesCount < 2 then return false end
    if totalPoints < 25 then return false end
    local w = maxX - minX
    local h = maxY - minY
    if w == 0 or h == 0 then return false end
    if (w / h) > 8 or (h / w) > 8 then return false end
    if theme == "saw" then
        local zigzagCount = 0
        for _, s in ipairs(strokes) do
            if #s[1] >= 3 then
                for i = 2, #s[1] - 1 do
                    local diff1 = s[2][i] - s[2][i-1]
                    local diff2 = s[2][i+1] - s[2][i]
                    if (diff1 > 0 and diff2 < 0) or (diff1 < 0 and diff2 > 0) then
                        zigzagCount = zigzagCount + 1
                    end
                end
            end
        end
        if zigzagCount < 3 then return false end
    end
    if theme == "brain" then
        local curvePoints = 0
        for _, s in ipairs(strokes) do
            if #s[1] >= 5 then
                for i = 3, #s[1] - 2 do
                    local vx1 = s[1][i-1] - s[1][i-2]
                    local vy1 = s[2][i-1] - s[2][i-2]
                    local vx2 = s[1][i] - s[1][i-1]
                    local vy2 = s[2][i] - s[2][i-1]
                    local vx3 = s[1][i+1] - s[1][i]
                    local vy3 = s[2][i+1] - s[2][i]
                    local dot1 = vx1 * vx2 + vy1 * vy2
                    local dot2 = vx2 * vx3 + vy2 * vy3
                    if dot1 < -50 and dot2 < -50 then
                        curvePoints = curvePoints + 1
                    end
                end
            end
        end
        if curvePoints < 2 then return false end
    end
    if theme == "drums" then
        local loops = 0
        for _, s in ipairs(strokes) do
            if #s[1] >= 5 then
                local firstX, firstY = s[1][1], s[2][1]
                local lastX, lastY = s[1][#s[1]], s[2][#s[2]]
                local dist = math.sqrt((firstX - lastX)^2 + (firstY - lastY)^2)
                if dist < 30 then loops = loops + 1 end
            end
        end
        if loops < 2 then return false end
    end
    if theme == "jail" then
        local verticalLines = 0
        for _, s in ipairs(strokes) do
            if #s[1] >= 3 then
                local width = math.abs(s[1][1] - s[1][#s[1]])
                local height = math.abs(s[2][1] - s[2][#s[2]])
                if height > width * 1.5 then verticalLines = verticalLines + 1 end
            end
        end
        if verticalLines < 2 then return false end
    end
    if theme == "jacket" then
        local hasArms = false
        local hasBody = false
        for _, s in ipairs(strokes) do
            if #s[1] >= 5 then
                local width = math.abs(s[1][1] - s[1][#s[1]])
                local height = math.abs(s[2][1] - s[2][#s[2]])
                if width > height then hasArms = true end
                if height > width then hasBody = true end
            end
        end
        if not hasArms or not hasBody then return false end
    end
    if theme == "stitches" then
        local facesDetected = 0
        for _, s in ipairs(strokes) do
            if #s[1] >= 5 then
                local firstX, firstY = s[1][1], s[2][1]
                local lastX, lastY = s[1][#s[1]], s[2][#s[2]]
                local dist = math.sqrt((firstX - lastX)^2 + (firstY - lastY)^2)
                if dist < 25 then facesDetected = facesDetected + 1 end
            end
        end
        if facesDetected > 1 then return false end
    end
    if theme == "elephant" or theme == "giraffe" or theme == "lion" or theme == "horse" or theme == "dragon" or theme == "penguin" or theme == "flamingo" then
        local animalWidth = maxX - minX
        local animalHeight = maxY - minY
        if (animalWidth < 80 and animalHeight < 80) then return false end
    end
    local complexThemeChecks = {
        elephant = function() return hasExtension(strokes, "left") end,
        flamingo = function() return hasExtension(strokes, "down") end,
        broccoli = function() return hasExtension(strokes, "up") and hasExtension(strokes, "down") end,
        broom = function() return hasExtension(strokes, "down") end,
    }
    if complexThemeChecks[theme] and not complexThemeChecks[theme]() then return false end
    return true
end

