function normalizeTheme(theme)
    if not theme then return nil end
    local t = tostring(theme):lower():gsub("%s+", " "):gsub("^%s+",""):gsub("%s+$",""):gsub("%d+$","")
    local mapped = themeMapping[t]
    if mapped then return mapped end
    return t
end

