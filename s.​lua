    self._blinkRunning = false
    self._loopActive = true
    return self
end

function PigGUIManager:storeComponent(name, instance)
    self.Components[name] = instance
end

function PigGUIManager:trackTween(tween)
    table.insert(self._tweens, tween)
end

function PigGUIManager:trackConnection(conn)
    table.insert(self._connections, conn)
end

function PigGUIManager:destroy()
    self._loopActive = false
    self._blinkRunning = false
    for _, tween in ipairs(self._tweens) do
        pcall(function() tween:Cancel() end)
    end
    for _, conn in ipairs(self._connections) do
        pcall(function() conn:Disconnect() end)
    end
end

