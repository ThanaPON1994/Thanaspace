-- ============================================================
-- 2. อนิเมชั่นตากระพริบ (Blink Animation)
-- ============================================================
function PigGUIManager:startBlinkLoop()
    self._blinkRunning = true

    task.spawn(function()
        while self._blinkRunning and self._loopActive and self.MainFrame do
            -- รอสุ่ม 3-7 วินาที (ให้ดูเป็นธรรมชาติ)
            task.wait(math.random(3, 7))

            -- ถ้าถูกหยุดให้ออก
            if not self._blinkRunning or not self._loopActive then break end

            -- กระพริบตาทั้ง 2 ข้างพร้อมกัน
            for i = 0, 1 do
                local eye = self.Components["Eye_" .. i]
                if eye and eye.Parent then

                    -- ========== ปิดตา ==========
                    local closeTween = TweenService:Create(eye, TweenInfo.new(0.08, Enum.EasingStyle.Quad), {
                        Size = UDim2.new(GUI_CONFIG.SIZES.EYE_SIZE * 1.8, 0, 0.05, 0)  -- บีบให้แบน
                    })
                    self:trackTween(closeTween)
                    closeTween:Play()

                    -- ========== เปิดตา ==========
                    -- รอให้ปิดตาเสร็จก่อน แล้วค่อยเปิด
                    local conn = closeTween.Completed:Connect(function()
                        if self._blinkRunning and self._loopActive then
                            local openTween = TweenService:Create(eye, TweenInfo.new(0.08, Enum.EasingStyle.Quad), {
                                Size = UDim2.new(GUI_CONFIG.SIZES.EYE_SIZE * 1.8, 0, GUI_CONFIG.SIZES.EYE_SIZE * 1.8, 0)  -- กลับมาขนาดปกติ
                            })
                            self:trackTween(openTween)
                            openTween:Play()
                        end
                    end)
                    self:trackConnection(conn)
                end
            end

            -- รออีกนิดก่อนกระพริบครั้งต่อไป
            task.wait(0.3)
        end
    end)
end

