-- ✅ จุดที่ 2: แทนที่ isGoodDrawing ทั้งหมด
function isGoodDrawing(theme, strokes)
    if not strokes or #strokes == 0 then return false end

    local totalPoints = 0
    local validStrokes = 0
    local minX, maxX, minY, maxY = math.huge, -math.huge, math.huge, -math.huge
    local strokeLengths = {}

    for _, s in ipairs(strokes) do
        if type(s) == "table" and #s >= 2 and type(s[1]) == "table" and type(s[2]) == "table" 
           and #s[1] > 0 and #s[2] > 0 and #s[1] == #s[2] then
            validStrokes = validStrokes + 1
            local len = #s[1]
            totalPoints = totalPoints + len
            table.insert(strokeLengths, len)

            for i = 1, len do
                minX = math.min(minX, s[1][i])
                maxX = math.max(maxX, s[1][i])
                minY = math.min(minY, s[2][i])
                maxY = math.max(maxY, s[2][i])
            end
        end
    end

    if validStrokes < 2 then return false end
    if totalPoints < 20 then return false end

    local w = maxX - minX
    local h = maxY - minY
    if w <= 0 or h <= 0 then return false end
    if (w / h) > 10 or (h / w) > 10 then return false end

    table.sort(strokeLengths)
    local longest = strokeLengths[#strokeLengths]
    if longest > totalPoints * 0.75 then return false end
    if strokeLengths[1] < 2 and #strokeLengths > 5 then return false end

    local area = w * h
    local density = totalPoints / area
    if density > 2.0 then return false end
    if density < 0.0005 then return false end

    local checks = {
        saw = function()
            local zigzag = 0
            for _, s in ipairs(strokes) do
                if #s[1] >= 4 then
                    for i = 2, #s[1] - 1 do
                        local d1 = s[2][i] - s[2][i-1]
                        local d2 = s[2][i+1] - s[2][i]
                        if d1 * d2 < 0 then zigzag = zigzag + 1 end
                    end
                end
            end
            return zigzag >= 3
        end,
        brain = function()
            local curves = 0
            for _, s in ipairs(strokes) do
                if #s[1] >= 6 then
                    for i = 3, #s[1] - 2 do
                        local cross1 = (s[1][i-1]-s[1][i-2])*(s[2][i]-s[2][i-1]) - (s[2][i-1]-s[2][i-2])*(s[1][i]-s[1][i-1])
                        local cross2 = (s[1][i]-s[1][i-1])*(s[2][i+1]-s[2][i]) - (s[2][i]-s[2][i-1])*(s[1][i+1]-s[1][i])
                        if cross1 * cross2 < 0 then curves = curves + 1 end
                    end
                end
            end
            return curves >= 2
        end,
        drums = function()
            local loops = 0
            for _, s in ipairs(strokes) do
                if #s[1] >= 5 then
                    local dx = s[1][1] - s[1][#s[1]]
                    local dy = s[2][1] - s[2][#s[2]]
                    if math.sqrt(dx*dx + dy*dy) < math.min(w, h) * 0.3 then loops = loops + 1 end
                end
            end
            return loops >= 2
        end,
        jail = function()
            local verts = 0
            for _, s in ipairs(strokes) do
                if #s[1] >= 3 then
                    local sw = math.abs(s[1][1] - s[1][#s[1]])
                    local sh = math.abs(s[2][1] - s[2][#s[2]])
                    if sh > sw * 1.5 then verts = verts + 1 end
                end
            end
            return verts >= 2
        end,
        jacket = function()
            local hasWide, hasTall = false, false
            for _, s in ipairs(strokes) do
                if #s[1] >= 4 then
                    local sw = math.abs(s[1][1] - s[1][#s[1]])
                    local sh = math.abs(s[2][1] - s[2][#s[2]])
                    if sw > sh * 1.2 then hasWide = true end
                    if sh > sw * 1.2 then hasTall = true end
                end
            end
            return hasWide and hasTall
        end,
        stitches = function()
            local closed = 0
            for _, s in ipairs(strokes) do
                if #s[1] >= 5 then
                    local dx = s[1][1] - s[1][#s[1]]
                    local dy = s[2][1] - s[2][#s[2]]
                    if math.sqrt(dx*dx + dy*dy) < 25 then closed = closed + 1 end
                end
            end
            return closed <= 1
        end,
        elephant = function() return validStrokes >= 4 and hasExtension(strokes, "left") and w > 80 end,
        giraffe = function() return validStrokes >= 4 and hasExtension(strokes, "up") and h > w * 1.2 end,
        flamingo = function() return validStrokes >= 3 and hasExtension(strokes, "down") and h > w end,
        lion = function() return validStrokes >= 4 and w > 70 and h > 70 end,
        horse = function() return validStrokes >= 4 and w > 80 and h > 60 end,
        dragon = function() return validStrokes >= 4 and w > 80 and h > 60 end,
        penguin = function() return validStrokes >= 3 and h > w * 0.8 end,
        broccoli = function() return hasExtension(strokes, "up") and hasExtension(strokes, "down") and validStrokes >= 3 end,
        broom = function() return hasExtension(strokes, "down") and validStrokes >= 2 end,
        grapes = function() return validStrokes >= 5 end,
        book = function() return validStrokes >= 3 end,
        leg = function() return validStrokes >= 3 and h > w * 1.5 end,
        ["light bulb"] = function() return validStrokes >= 3 and h > w end,
        ["paint can"] = function() return validStrokes >= 2 end,
        steak = function() return validStrokes >= 3 end,
        bird = function() return validStrokes >= 3 and hasExtension(strokes, "right") end,
        trumpet = function() return validStrokes >= 4 and w > h end,
        popsicle = function() return validStrokes >= 2 and h > w end,
    }

    if checks[theme] then
        return checks[theme]()
    end

    local animals = {
        elephant=true, giraffe=true, lion=true, horse=true, dragon=true, penguin=true, flamingo=true,
        cat=true, dog=true, bird=true, fish=true, shark=true, whale=true, crocodile=true, monkey=true,
        bear=true, tiger=true, zebra=true, kangaroo=true, sheep=true, cow=true, pig=true, rabbit=true,
        mouse=true, snake=true, turtle=true, frog=true, spider=true, butterfly=true, bee=true, ant=true,
        camel=true, dolphin=true, owl=true, parrot=true, panda=true, snail=true, swan=true,
        hedgehog=true, rhinoceros=true, scorpion=true, squirrel=true, octopus=true, lobster=true,
        mosquito=true, mermaid=true
    }
    if animals[theme] then
        return w > 50 and h > 50 and validStrokes >= 3
    end

    return true
end

